{
    "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    //"baseUrl": "./",
    "paths": {
        "@pages/*": ["./lib/pages/*"],
        "@datafactory/*": ["./lib/datafactory/*"],
        "@fixtures/*": ["./lib/fixtures/*"],
        "@tests/*": ["./tests/*"]
    }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}